NODE_ENV=production
PORT=5000
CLIENT_ORIGIN=https://app.workingbeam.example
TRUST_PROXY=1
FORCE_HTTPS=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
SUPABASE_STATE_ROW_ID=default

VERIFICATION_CODE_PEPPER=replace-with-at-least-32-random-characters
REQUIRE_EMAIL_VERIFICATION=true
SMTP_URL=smtps://user:password@smtp.example.com:465
EMAIL_FROM="WorkingBeam <security@workingbeam.example>"

PUSH_WEBHOOK_URL=https://push-provider.example.com/workingbeam/events
PUSH_WEBHOOK_TOKEN=replace-with-push-provider-token

BEAM_WALLET_API_URL=https://wallet.internal.example/api/wallet
BEAM_WALLET_API_KEY=replace-with-wallet-api-acl-key
BEAM_ESCROW_ADDRESS=replace-with-live-beam-escrow-address-or-token
BEAM_GROTH_PER_BEAM=100000000
BEAM_TX_FEE_GROTH=100000
