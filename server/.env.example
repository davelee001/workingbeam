# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000
DATA_FILE=./data/workingbeam.json
TRUST_PROXY=

VERIFICATION_CODE_PEPPER=development-only-change-this-random-secret

# SMTP delivery is mandatory in production. Without SMTP_URL, development logs codes locally.
SMTP_URL=
EMAIL_FROM=WorkingBeam Security <security@example.com>

# Leave BEAM_WALLET_API_URL empty to use the local deterministic mock wallet.
# A live wallet-api should use HTTP mode, TLS, an ACL key, and an IP allowlist.
BEAM_WALLET_API_URL=
BEAM_WALLET_API_KEY=
BEAM_ESCROW_ADDRESS=
BEAM_GROTH_PER_BEAM=100000000
BEAM_TX_FEE_GROTH=100000
